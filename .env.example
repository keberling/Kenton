PORT=3000
DATA_DIR=./server/data
CLIENT_ORIGIN=http://localhost:3000
SITE_MATCH_RADIUS_M=100
SITE_SOFT_MATCH_CUSHION_M=1609

# Recommended for production — Nominatim requires a contact email for server use
NOMINATIM_EMAIL=you@yourcompany.com

# Microsoft Entra ID (Azure AD) — optional until app registration is complete
# When both are set, SSO is enabled and uploads require sign-in by default.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Optional: defaults to api://{AZURE_CLIENT_ID}/access_as_user
AZURE_API_SCOPE=
# Set to false to allow anonymous uploads while SSO is configured (dev only)
AUTH_REQUIRED=true