PORT=3000
DATA_DIR=./server/data
CLIENT_ORIGIN=http://localhost:3000
SITE_MATCH_RADIUS_M=100
SITE_SOFT_MATCH_CUSHION_M=1609
SITE_MAX_MATCH_DISTANCE_M=3219

# Recommended for production — Nominatim requires a contact email for server use
NOMINATIM_EMAIL=you@yourcompany.com

# --- Microsoft Entra ID (Azure AD) SSO ---
# Register a single app in Entra ID for both staff sign-in and nightly SharePoint backups.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Required for unattended SharePoint backups (application permission / client credentials)
AZURE_CLIENT_SECRET=
# Optional legacy custom API scope (requires Expose an API in Entra). Leave blank — Kenton uses User.Read.
AZURE_API_SCOPE=
# Staff pages require sign-in when Azure is configured (default true)
AUTH_REQUIRED=true
# Keep uploads public even when SSO is enabled (default false)
AUTH_UPLOAD_REQUIRED=false

# --- SharePoint backups ---
BACKUP_ENABLED=true
BACKUP_RETENTION=10
# Nightly at 2:00 AM by default (cron syntax)
BACKUP_CRON=0 2 * * *
BACKUP_TIMEZONE=America/Chicago
# SharePoint site URL and backup folder are configured in-app at /app/settings

# Kaseya Autotask PSA — optional client/address import
AUTOTASK_API_USERNAME=
AUTOTASK_API_SECRET=
AUTOTASK_INTEGRATION_CODE=
AUTOTASK_ZONE_URL=